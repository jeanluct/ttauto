(* Beginning of Notebook Content *)
Notebook[{

Cell[CellGroupData[{
Cell["Initialization", "Subsection"],

Cell[BoxData[
 RowBox[{
  RowBox[{"AppendTo", "[",
   RowBox[{"$Path", ",",
    RowBox[{"ToFileName", "[",
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}],
      ",", "\"\<../../mathematica\>\""}], "]"}]}], "]"}], ";"}]], "Input"],

Cell[BoxData[
 RowBox[{"<<", "TrainTracks.m"}]], "Input"]
}]],

Cell[CellGroupData[{

Cell["Bad pA", "Subsection"],

Cell["Load first invariant component of traintrack automaton:", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tt", "=",
   RowBox[{"First", "[",
    RowBox[{"<<", "\"\<n=6_5_bad_tt_data.m\>\""}], "]"}]}], ";"}]], "Input"],

Cell["\<\
Load the ten pA candidates up to length 7 found in the automaton:\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pAcands", "=",
   RowBox[{"<<", "\"\<pA_n=6_5_1_inv.m\>\""}]}], ";"}]], "Input"],

Cell[BoxData[
 RowBox[{"Length", "[", "pAcands", "]"}]], "Input"],

Cell["Check dilatations:", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FindRoot", "[",
    RowBox[{"#", ",",
     RowBox[{"{",
      RowBox[{"x", ",", "5"}], "}"}]}], "]"}], "&"}], "/@",
  RowBox[{"(",
   RowBox[{"polynomial", "/.", "pAcands"}], ")"}]}]], "Input"],

Cell["The \"bad pA\" is the second one:", "Text"],

Cell[BoxData[
 RowBox[{"pAcands", "\[LeftDoubleBracket]", "2",
  "\[RightDoubleBracket]"}]], "Input"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"path", "=",
   RowBox[{
    RowBox[{"(",
     RowBox[{"pathlist", "/.",
      RowBox[{
      "pAcands", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}],
     ")"}], "\[LeftDoubleBracket]",
    RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}], ";"}], "\[IndentingNewLine]",
 RowBox[{"path", " ", "=",
  RowBox[{"path", "+", "1", " ",
   RowBox[{"(*",
    RowBox[{"1", "-",
     RowBox[{"indexed", " ", "for", " ", "Mathematica"}]}],
    "*)"}]}]}]}], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PlotTrainTrack", "[",
    RowBox[{"tt", "\[LeftDoubleBracket]",
     RowBox[{"1", ",", "#", ",", "2"}], "\[RightDoubleBracket]"}], "]"}],
   "&"}], "/@", "path"}]], "Input"],

Cell[BoxData[
 RowBox[{"Grid", "[",
  RowBox[{
   RowBox[{
    RowBox[{"{",
     RowBox[{"#", ",",
      RowBox[{"tt", "\[LeftDoubleBracket]",
       RowBox[{"1", ",", "#", ",", "1"}], "\[RightDoubleBracket]"}]}], "}"}],
    "&"}], "/@", "path"}], "]"}]], "Input"]
}]]
}]
(* End of Notebook Content *)
